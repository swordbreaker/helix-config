# --- Vue / Nuxt LSP setup ---

[language-server.vuels]
command = "helix-vue-proxy"
args = [
  "--plugin-path", "/home/tobi/.nvm/versions/node/v24.9.0/lib/node_modules/@vue/typescript-plugin",
  "--tsdk", "/home/tobi/.nvm/versions/node/v24.9.0/lib/node_modules/typescript/lib",
  "--log-level", "waring",
  "--log-file", "/tmp/helix-vue-proxy.log"
]

[[language]]
name = "typescript"
language-servers = ["typescript-language-server"]
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
auto-format = true

[[language]]
name = "tsx"
language-servers = ["typescript-language-server"]
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
auto-format = true

[[language]]
name = "javascript"
language-servers = ["typescript-language-server"]
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
auto-format = true

[[language]]
name = "jsx"
language-servers = ["typescript-language-server"]
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
auto-format = true

[[language]]
name = "json"
language-servers = ["typescript-language-server"]
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
auto-format = true

[[language]]
name = "vue"
scope = "source.vue"
injection-regex = "vue"
file-types = ["vue"]
auto-format = true
formatter = { command = "biome", args = ["format", "--stdin-file-path", "%%"] }
language-servers = [{ name = "vuels", except-features = ["document-highlight"] }] 

# --- .env file support ---

[language-server.ecolog-lsp]
command = "ecolog-lsp"

[[language]]
name = "env"
scope = "source.env"
file-types = [".env", ".env.*"]
language-servers = ["ecolog-lsp"]
grammar = "bash"

[language.indent]
style = "spaces"
width = 4
tab-width = 4
unit = "    "
